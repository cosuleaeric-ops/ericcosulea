{
  "manifest_version": 3,
  "name": "EliteMail (personal)",
  "version": "1.23.0",
  "description": "Open + click tracking pentru Gmail, self-hosted pe ericcosulea.ro. Uz personal.",
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://mail.google.com/*",
    "https://www.ericcosulea.ro/*",
    "https://ericcosulea.ro/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "EliteMail — opțiuni în click dreapta → Opțiuni"
  }
}
