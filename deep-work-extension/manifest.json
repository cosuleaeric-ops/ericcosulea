{
  "manifest_version": 3,
  "name": "Elite Deep Work Blocker",
  "version": "1.0.0",
  "description": "Blocks distracting social media sites while the Elite Deep Work timer is running.",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "*://facebook.com/*",
    "*://*.facebook.com/*",
    "*://instagram.com/*",
    "*://*.instagram.com/*",
    "*://x.com/*",
    "*://*.x.com/*",
    "*://twitter.com/*",
    "*://*.twitter.com/*",
    "*://reddit.com/*",
    "*://*.reddit.com/*",
    "*://tiktok.com/*",
    "*://*.tiktok.com/*",
    "*://linkedin.com/*",
    "*://*.linkedin.com/*",
    "*://ericcosulea.ro/*",
    "*://*.ericcosulea.ro/*",
    "*://deepwork.ro/*",
    "*://www.deepwork.ro/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://ericcosulea.ro/deep-work/*",
        "*://*.ericcosulea.ro/deep-work/*",
        "*://deepwork.ro/*",
        "*://www.deepwork.ro/*"
      ],
      "js": [
        "deep-work-bridge.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://x.com/*",
        "*://*.x.com/*",
        "*://twitter.com/*",
        "*://*.twitter.com/*",
        "*://linkedin.com/*",
        "*://*.linkedin.com/*"
      ],
      "js": [
        "site-blocker.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html",
        "blocked.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
